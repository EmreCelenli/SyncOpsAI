{
   "mcpServers": {
     "watsonx-orchestrate-adk-docs": {
       "command": "uvx",
       "args": [
         "mcp-proxy",
         "--transport",
         "streamablehttp",
         "https://developer.watson-orchestrate.ibm.com/mcp"
       ]
     },
     "watsonx-orchestrate-adk": {
       "command": "uvx",
       "args": [
         "ibm-watsonx-orchestrate-mcp-server"
       ],
       "env": {
         "WXO_MCP_WORKING_DIRECTORY": "/absolute/path/to/project",
         "WXO_MCP_DEBUG": ""
       },
       "timeout": 300
     }
   }
 }